# =============================================================================
# Alibi Configuration
# =============================================================================
# Copy to .env and uncomment/adjust the lines you need.
# Variables use ALIBI_ prefix (except TELEGRAM_BOT_TOKEN).
#
# QUICK START: Only two things are truly required:
#   1. Ollama running with glm-ocr model (ollama pull glm-ocr)
#   2. ALIBI_OLLAMA_URL set below
#
# Everything else has sensible defaults. Commented-out lines show the default
# values -- you only need to uncomment them if you want to change them.
# =============================================================================

# =============================================================================
# CORE (minimal setup)
# =============================================================================

# Ollama endpoint (must have glm-ocr model pulled)
ALIBI_OLLAMA_URL=http://127.0.0.1:11434

# Default currency for extracted amounts
ALIBI_DEFAULT_CURRENCY=EUR

# SQLite database path (relative to project root or absolute)
# ALIBI_DB_PATH=data/alibi.db

# =============================================================================
# DOCUMENT VAULT (optional)
# =============================================================================
# Point alibi at a folder (e.g. Obsidian vault) to enable the file watcher
# and auto-ingest documents from an inbox subfolder.

# Path to your vault / document root
# ALIBI_VAULT_PATH=/path/to/your/vault

# Inbox subfolder within the vault (watched for new documents)
# Supports typed subfolders: receipts/, invoices/, payments/, statements/
# ALIBI_INBOX_FOLDER=inbox/documents

# =============================================================================
# 3-STAGE EXTRACTION PIPELINE
# =============================================================================
# Stage 1: OCR via glm-ocr (always local, ~2-6s per image)
# Stage 2: Heuristic text parser (no model, ~2ms, handles ~64% of documents)
# Stage 3: LLM structuring (only when parser confidence < threshold)
#
# Choose ONE backend for Stage 3:
#
# Option A -- Local (free, slower, needs ~8GB RAM for qwen3:8b):
#   ALIBI_OLLAMA_STRUCTURE_MODEL=qwen3:8b
#   ALIBI_GEMINI_EXTRACTION_ENABLED=false
#
# Option B -- Cloud via Gemini (fast, ~$0.001/doc, needs API key):
#   ALIBI_GEMINI_EXTRACTION_ENABLED=true
#   ALIBI_GEMINI_API_KEY=your-key-here
#   ALIBI_GEMINI_EXTRACTION_MODEL=gemini-2.5-flash

# Parser confidence threshold: skip Stage 3 when parser scores at or above
# this value. 0.9 = skip LLM for well-parsed docs. 1.1 = always run LLM.
# ALIBI_SKIP_LLM_THRESHOLD=0.9

# OCR backend: "ollama" (recommended) or "doctr" (experimental, CPU-only)
# ALIBI_OCR_BACKEND=ollama

# Primary OCR model
# ALIBI_OLLAMA_OCR_MODEL=glm-ocr

# OCR timeout per image in seconds
# ALIBI_OCR_TIMEOUT=120

# Fallback OCR model for non-Latin scripts (Greek, Russian, CJK).
# Activates automatically when the document's country uses non-Latin script.
# Default: gemma4 (27B MoE, 9.6GB, 140+ languages, Apache 2.0)
# Requires: ollama pull gemma4
# ALIBI_OLLAMA_OCR_FALLBACK_MODEL=gemma4

# Vision model for offline document classification (rarely needed)
# ALIBI_OLLAMA_MODEL=qwen3-vl:30b

# Total LLM timeout for Stage 3 structuring in seconds
# ALIBI_LLM_TIMEOUT=600

# =============================================================================
# PROCESSING
# =============================================================================

# Auto-run extraction pipeline on document ingest (via API/Telegram upload).
# When false, documents are stored but not processed until you run `lt process`.
# ALIBI_AUTO_PROCESS=false

# Stage 3 prompt strategy:
#   "specialized" = type-specific prompts (receipt, invoice, etc.) -- better accuracy
#   "universal"   = single prompt for all document types -- simpler, experimental
# ALIBI_PROMPT_MODE=specialized

# Display language for the web UI and CLI output.
# "original" preserves the source document language.
# ALIBI_DISPLAY_LANGUAGE=original

# Directory for .alibi.yaml extraction caches (relative to project root).
# These files are the human-editable intermediary between OCR and the database.
# ALIBI_YAML_STORE=data/yaml_store

# =============================================================================
# IMAGE OPTIMIZATION
# =============================================================================
# Runs automatically on ingest (before OCR): strips EXIF, resizes, compresses.
# Reduces storage and speeds up OCR without affecting accuracy.

# Enable/disable optimization (default: true)
# ALIBI_OPTIMIZE_IMAGES=true

# Max image dimension in pixels (longest side). 2048 balances OCR quality vs size.
# ALIBI_IMAGE_MAX_DIM=2048

# JPEG compression quality (1-100). 85 is a good balance.
# ALIBI_IMAGE_QUALITY=85

# =============================================================================
# API SERVER
# =============================================================================
# The REST API serves the Web UI, Swagger docs (/docs), and all programmatic access.
# Start with: uv run lt serve

# Bind address (127.0.0.1 = localhost only, 0.0.0.0 = all interfaces)
# ALIBI_API_HOST=127.0.0.1

# Listen port
# ALIBI_API_PORT=3100

# Legacy single API key (optional). For multi-user setups, use mnemonic keys
# instead: uv run lt user create && uv run lt user api-key create <user-id>
# ALIBI_API_KEY=

# =============================================================================
# TELEGRAM BOT (optional)
# =============================================================================
# Mobile document capture and conversational queries via Telegram.
# Requires: uv sync --extra telegram
# Setup: create a bot via @BotFather, then set the token below.
# Start: uv run lt telegram start

# TELEGRAM_BOT_TOKEN=your-bot-token

# Restrict bot access to specific Telegram user IDs (comma-separated).
# STRONGLY RECOMMENDED for security. Find your ID via @userinfobot on Telegram.
# When unset, the bot accepts messages from ANY Telegram user.
# ALIBI_TELEGRAM_ALLOWED_USERS=123456789,987654321

# =============================================================================
# PRODUCT ENRICHMENT (optional)
# =============================================================================
# Enrichment adds brand, category, unit_quantity, and nutritional data to items
# extracted from receipts. Multiple tiers cascade automatically:
#   1. Historical data (free, instant)
#   2. Open Food Facts barcode lookup (free, ~1s)
#   3. UPCitemdb barcode lookup (free, 100 req/day)
#   4. GS1 barcode prefix decoding (free, instant)
#   5. Fuzzy name matching against known products (free, instant)
#   6. Local LLM inference (free, ~5s, requires Ollama)
#   7. Gemini mega-batch (fast, ~$0.001/batch, requires API key below)
#   8. Anthropic cloud (accurate, ~$0.01/batch, requires API key below)
#
# Tiers 1-6 work without any API keys. Enable 7-8 for better coverage.

# Gemini mega-batch: enriches all items in a single LLM call (brand + category)
# ALIBI_GEMINI_ENRICHMENT_ENABLED=false
# ALIBI_GEMINI_ENRICHMENT_MODEL=gemini-2.5-flash

# Anthropic cloud enrichment (sends only product name + barcode, no PII)
# ALIBI_CLOUD_ENRICHMENT_ENABLED=false
# ALIBI_ANTHROPIC_API_KEY=sk-ant-...
# ALIBI_CLOUD_ENRICHMENT_MODEL=claude-sonnet-4-6

# Contribute enriched products back to Open Food Facts (good citizenship).
# Only submits products that OFF doesn't already have.
# ALIBI_OFF_CONTRIBUTION_ENABLED=false

# Timeout for local LLM enrichment (tier 6) in seconds
# ALIBI_LLM_ENRICHMENT_TIMEOUT=60

# =============================================================================
# SCHEDULED ENRICHMENT (watcher daemon)
# =============================================================================
# When enabled, the watcher daemon periodically enriches items in the background.
# Three independent cycles run on staggered intervals:
#   - Barcode + name matching (tiers 1-5): every 6 hours
#   - Gemini mega-batch (tier 7): every 3 days (requires GEMINI key)
#   - Maintenance (template learning, identity cleanup): every 7 days
#
# Just set ENABLED=true to use the defaults. Override intervals only if needed.

# ALIBI_ENRICHMENT_SCHEDULE_ENABLED=false
# ALIBI_ENRICHMENT_SCHEDULE_INTERVAL=21600          # Barcode/matching cycle (seconds, default: 6h)
# ALIBI_ENRICHMENT_SCHEDULE_GEMINI_INTERVAL=259200   # Gemini batch cycle (seconds, default: 3 days)
# ALIBI_ENRICHMENT_SCHEDULE_MAINTENANCE_INTERVAL=604800  # Maintenance cycle (seconds, default: 7 days)
# ALIBI_ENRICHMENT_SCHEDULE_LIMIT=500                # Max items per enrichment run

# =============================================================================
# MINDSDB PREDICTIONS (optional)
# =============================================================================
# ML-powered spending forecasts and automatic item categorization.
# Requires a self-hosted MindsDB instance (no cloud dependency).
# Setup: docker run -p 47334:47334 mindsdb/mindsdb:lightwood
# Then train models: uv run lt predictions train-forecast
# See README.md "Predictions (MindsDB)" section for full usage.

# ALIBI_MINDSDB_ENABLED=false
# ALIBI_MINDSDB_URL=http://127.0.0.1:47334

# =============================================================================
# CUSTOM ALIAS FILES (optional)
# =============================================================================
# Override unit and vendor normalization with your own YAML mappings.
# See data/unit_aliases.example.yaml and data/vendor_aliases.example.yaml.

# ALIBI_UNIT_ALIASES_PATH=data/unit_aliases.yaml
# ALIBI_VENDOR_ALIASES_PATH=data/vendor_aliases.yaml

# =============================================================================
# VECTOR STORE (optional)
# =============================================================================
# LanceDB-powered semantic search across documents, facts, and items.
# Enables "find similar" queries via MCP and API.
# Requires: uv sync --extra vector
# Once enabled, vectors are built automatically on document ingest.

# ALIBI_LANCE_PATH=data/lancedb

# =============================================================================
# ANALYTICS EXPORT (optional)
# =============================================================================
# Push alibi data (facts, items, annotations, documents) to an external
# analytics service via HTTP POST. The payload is a JSON object with four
# arrays: facts, fact_items, annotations, documents.
#
# This is an integration point for building your own dashboards, BI tools,
# or LLM-powered analytics on top of alibi's structured data. Each push
# sends a full snapshot (not incremental).
#
# Expected endpoint: POST {url}/v1/ingest/alibi
# Expected request body: {"facts": [...], "fact_items": [...],
#                          "annotations": [...], "documents": [...]}
# Expected response: {"facts_count": N, "items_count": N, ...}
#
# You can build a receiver using any framework (FastAPI, Express, etc.)
# that accepts this JSON and stores it in your analytics database of choice
# (PostgreSQL, ClickHouse, DuckDB, etc.).

# ALIBI_ANALYTICS_EXPORT_ENABLED=false
# ALIBI_ANALYTICS_STACK_URL=http://localhost:8070
